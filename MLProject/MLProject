name: Heart_Disease_Classification

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path: {type: string, default: "preprocessing/heart_preprocessing.csv"}
      n_estimators: {type: int, default: 100}
      random_state: {type: int, default: 42}
    command: "python modelling.py --data_path {data_path} --n_estimators {n_estimators} --random_state {random_state}"
